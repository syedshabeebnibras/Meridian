# Copy to .env.local. Server-only — never prefix with NEXT_PUBLIC_.

# Auth.js v5. Required in production.
AUTH_SECRET=
AUTH_URL=http://localhost:3001
# AUTH_TRUST_HOST=true

# Web runtime label. Set to production on Vercel.
MERIDIAN_ENV=dev

# Postgres for Auth.js/user/session reads. Prefer DATABASE_URL_JS for
# node-postgres; DATABASE_URL may use the Python postgresql+psycopg scheme.
DATABASE_URL_JS=postgresql://meridian:meridian@localhost:5432/meridian
# DATABASE_URL=postgresql+psycopg://meridian:meridian@localhost:5432/meridian

# URL the server-side proxy hits. Leave commented for dev default.
ORCH_URL=http://127.0.0.1:8000

# Internal shared secret forwarded as X-Internal-Key to the orchestrator.
# Required when the orchestrator runs with MERIDIAN_ENV=staging|production.
ORCH_INTERNAL_KEY=
